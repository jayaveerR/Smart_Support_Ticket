{
  "entities": {
    "Ticket": {
      "title": "Support Ticket",
      "description": "A customer support ticket with status tracking and category-specific fields.",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string", "description": "Unique human-readable ticket ID" },
        "uid": { "type": "string", "description": "UID of the user who created the ticket" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "subject": { "type": "string", "description": "Ticket subject" },
        "category": { "type": "string", "enum": ["General", "Technical", "HR", "Payments", "Other", "Missing Cases"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] },
        "description": { "type": "string", "description": "Detailed description of the issue" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Resolved", "Paused"] },
        "type": { "type": "string", "enum": ["new_ticket", "status_update"] },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "aiSummary": { "type": "string", "description": "AI-generated summary of the ticket" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "lastSeenLocation": { "type": "string" }
          }
        },
        "imageUrl": { "type": "string", "description": "URL of uploaded image for missing cases" },
        "dateOfMissing": { "type": "string", "description": "Date of missing for missing cases" },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "message": { "type": "string" },
              "updatedAt": { "type": "number" }
            }
          }
        },
        "adminComment": { "type": "string", "description": "Latest comment from admin" }
      },
      "required": ["ticketId", "name", "email", "subject", "category", "priority", "description", "status", "createdAt", "timeline"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a ticket chat thread.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "UID of the sender" },
        "senderName": { "type": "string", "description": "Name of the sender" },
        "senderRole": { "type": "string", "enum": ["user", "admin"], "description": "Role of the sender" },
        "text": { "type": "string", "description": "Content of the message" },
        "createdAt": { "type": "number", "description": "Timestamp of message creation" }
      },
      "required": ["senderId", "senderName", "senderRole", "text", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Authenticated user's profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "phone": { "type": "string", "description": "User's phone number" },
        "department": { "type": "string", "description": "User's department" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" },
        "createdAt": { "type": "number", "description": "Timestamp of profile creation" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global system configuration settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Setting ID (usually 'default')" },
        "autoAssignment": { "type": "boolean", "description": "Whether to automatically assign tickets" },
        "maintenanceMode": { "type": "boolean", "description": "Whether the system is in maintenance mode" },
        "notificationEmail": { "type": "string", "format": "email", "description": "Email for system notifications" },
        "maxTicketsPerUser": { "type": "number", "description": "Maximum tickets a user can create" },
        "updatedAt": { "type": "number", "description": "Timestamp of last update" },
        "updatedBy": { "type": "string", "description": "UID of the admin who updated the settings" }
      },
      "required": ["id", "autoAssignment", "maintenanceMode", "notificationEmail", "maxTicketsPerUser", "updatedAt", "updatedBy"]
    }
  },
  "firestore": {
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Collection of all support tickets"
    },
    "/tickets/{ticketId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Subcollection of messages for a specific ticket"
    },
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "/settings/{settingId}": {
      "schema": "SystemSettings",
      "description": "Global system configuration"
    }
  }
}
